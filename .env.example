# DashScope API Key (required)
DASHSCOPE_API_KEY=your_api_key_here

# Model selection
PRIMARY_MODEL=qwen-plus
FALLBACK_MODEL_STRONG=qwen-max
FALLBACK_MODEL_WEAK=qwen-turbo
EMBEDDING_MODEL=text-embedding-v4

# Database (SQLite default, swap for PostgreSQL in production)
DB_URL=sqlite:///./medical_ai.db

# API
API_HOST=0.0.0.0
API_PORT=8000
STREAMLIT_PORT=8501
